generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookStatus {
  WANT
  READING
  READ
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  createdAt  DateTime @default(now())
  books      Book[]
}

model Book {
  id         Int        @id @default(autoincrement())
  userId     Int
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  author     String
  genre      String?
  year       Int?
  status     BookStatus @default(WANT)
  rating     Int?
  coverUrl   String?
  notes      String?
  summary    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  quotes     Quote[]
  characters Character[]
}

model Quote {
  id      Int     @id @default(autoincrement())
  bookId  Int
  book    Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  text    String
  chapter String?
}

model Character {
  id          Int    @id @default(autoincrement())
  bookId      Int
  book        Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  name        String
  description String?
}